# Copy this file to .env and fill in your real values.

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Server 2 SSH target
CAREGENT_SERVER2_HOST=your-server-2-ip-or-domain
CAREGENT_SERVER2_USER=ubuntu
CAREGENT_SERVER2_PORT=22
CAREGENT_SERVER2_IDENTITY_FILE=/home/dnhs01/.ssh/your-server-2-key.pem

# Server 2 PostgreSQL
CAREGENT_DB_HOST=your-server-2-ip-or-domain
CAREGENT_DB_PORT=5432
CAREGENT_DB_NAME=caregent
CAREGENT_DB_USER=caregent
CAREGENT_DB_PASSWORD=your-db-password
CAREGENT_POSTGRES_DSN=dbname=caregent user=caregent password=your-db-password host=your-server-2-ip-or-domain port=5432

